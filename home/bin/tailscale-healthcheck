#!/bin/sh
# Tailscale Health Check and Discord Notification
# Monitors Tailscale connection status and sends alerts via Discord webhook

set -eu

# Configuration
STATE_DIR="${HOME}/.local/state/tailscale-monitor"
STATE_FILE="${STATE_DIR}/last_state.json"
CONFIG_FILE="${HOME}/.config/tailscale-monitor/webhook.env"
HOSTNAME="${HOSTNAME:-$(hostname -s)}"
WARN_DAYS=30  # Warn if key expires within this many days

# Colors for Discord embeds
COLOR_ERROR=15158332    # Red
COLOR_WARNING=16776960  # Yellow
COLOR_SUCCESS=3066993   # Green
COLOR_INFO=3447003      # Blue

# Create state directory if it doesn't exist
mkdir -p "${STATE_DIR}"

# Load webhook configuration
if [ ! -f "${CONFIG_FILE}" ]; then
  echo "Error: Configuration file not found: ${CONFIG_FILE}"
  echo "Please copy .config/tailscale-monitor/webhook.env.example to webhook.env and configure it."
  exit 1
fi

# shellcheck disable=SC1090
. "${CONFIG_FILE}"

if [ -z "${DISCORD_WEBHOOK_URL:-}" ] || [ "${DISCORD_WEBHOOK_URL}" = "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN" ]; then
  echo "Error: DISCORD_WEBHOOK_URL not configured in ${CONFIG_FILE}"
  exit 1
fi

# Function: Send Discord notification
send_notification() {
  title="$1"
  description="$2"
  color="$3"

  # Build JSON payload
  payload=$(cat <<EOF
{
  "embeds": [{
    "title": "${title}",
    "description": "${description}",
    "color": ${color},
    "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "footer": {
      "text": "${HOSTNAME}"
    }
  }]
}
EOF
)

  # Send to Discord
  if ! curl -s -X POST \
    -H "Content-Type: application/json" \
    -d "${payload}" \
    "${DISCORD_WEBHOOK_URL}" >/dev/null 2>&1; then
    echo "Warning: Failed to send Discord notification"
    return 1
  fi

  return 0
}

# Function: Get current Tailscale status
get_tailscale_status() {
  if ! tailscale status --json 2>/dev/null; then
    echo '{"error": "tailscale_unavailable"}'
    return 1
  fi
  return 0
}

# Function: Check if weekly report is due
is_weekly_report_due() {
  # Check if it's Monday (1) and between 8:00-10:00
  day_of_week=$(date +%u)
  hour=$(date +%H)

  if [ "${day_of_week}" = "1" ] && [ "${hour}" -ge 8 ] && [ "${hour}" -lt 10 ]; then
    # Check if we already sent report today
    if [ -f "${STATE_DIR}/last_weekly_report" ]; then
      last_report=$(cat "${STATE_DIR}/last_weekly_report")
      today=$(date +%Y-%m-%d)
      if [ "${last_report}" = "${today}" ]; then
        return 1  # Already sent today
      fi
    fi
    return 0  # Report is due
  fi

  return 1  # Not time for report
}

# Function: Send weekly status report
send_weekly_report() {
  status_json="$1"

  # Parse status
  logged_out=$(echo "${status_json}" | grep -o '"LoggedOut":[^,]*' | cut -d: -f2 | tr -d ' ')
  self_online=$(echo "${status_json}" | grep -o '"Online":[^,}]*' | cut -d: -f2 | tr -d ' ' | head -1)
  key_expiry=$(echo "${status_json}" | grep -o '"KeyExpiry":"[^"]*"' | cut -d'"' -f4)

  # Calculate days until expiry
  if [ -n "${key_expiry}" ] && [ "${key_expiry}" != "null" ]; then
    expiry_epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "${key_expiry}" +%s 2>/dev/null || echo "0")
    current_epoch=$(date +%s)
    days_until_expiry=$(( (expiry_epoch - current_epoch) / 86400 ))
  else
    days_until_expiry="∞"
  fi

  # Build report
  if [ "${logged_out}" = "true" ]; then
    status_text="❌ Logged out"
    color=${COLOR_ERROR}
  elif [ "${self_online}" = "true" ]; then
    status_text="✅ Connected"
    color=${COLOR_SUCCESS}
  else
    status_text="⚠️  Offline"
    color=${COLOR_WARNING}
  fi

  report="**Tailscale Weekly Status Report**\n\n"
  report="${report}Status: ${status_text}\n"
  report="${report}Auth Key Expiry: ${days_until_expiry} days\n"
  report="${report}Hostname: ${HOSTNAME}\n"

  send_notification "📊 Weekly Tailscale Report" "${report}" "${color}"

  # Mark report as sent
  date +%Y-%m-%d > "${STATE_DIR}/last_weekly_report"
}

# Main health check logic
main() {
  # Get current status
  current_status=$(get_tailscale_status)

  # Check if tailscale command failed
  if echo "${current_status}" | grep -q '"error"'; then
    send_notification \
      "❌ Tailscale Error" \
      "Failed to get Tailscale status. The tailscaled daemon may not be running.\n\nHost: ${HOSTNAME}" \
      ${COLOR_ERROR}
    exit 1
  fi

  # Parse status JSON
  logged_out=$(echo "${current_status}" | grep -o '"LoggedOut":[^,]*' | cut -d: -f2 | tr -d ' ')
  self_online=$(echo "${current_status}" | grep -o '"Online":[^,}]*' | cut -d: -f2 | tr -d ' ' | head -1)
  key_expiry=$(echo "${current_status}" | grep -o '"KeyExpiry":"[^"]*"' | cut -d'"' -f4)

  # Load previous state
  prev_logged_out=""
  if [ -f "${STATE_FILE}" ]; then
    prev_logged_out=$(grep -o '"LoggedOut":[^,]*' "${STATE_FILE}" | cut -d: -f2 | tr -d ' ' || echo "")
  fi

  # Check 1: Logged out status
  if [ "${logged_out}" = "true" ]; then
    if [ "${prev_logged_out}" != "true" ]; then
      send_notification \
        "🚨 Tailscale Logged Out" \
        "Tailscale has been logged out on ${HOSTNAME}!\n\nYou will not be able to connect remotely until you log back in.\n\nTo fix:\n1. Access the machine locally\n2. Run: \`tailscale up --accept-routes --ssh --accept-dns\`" \
        ${COLOR_ERROR}
    fi
  fi

  # Check 2: Connection status
  if [ "${logged_out}" != "true" ] && [ "${self_online}" != "true" ]; then
    send_notification \
      "⚠️  Tailscale Offline" \
      "Tailscale is logged in but not connected on ${HOSTNAME}.\n\nThis may be a temporary network issue." \
      ${COLOR_WARNING}
  fi

  # Check 3: Key expiry warning
  if [ -n "${key_expiry}" ] && [ "${key_expiry}" != "null" ]; then
    expiry_epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "${key_expiry}" +%s 2>/dev/null || echo "0")
    current_epoch=$(date +%s)
    days_until_expiry=$(( (expiry_epoch - current_epoch) / 86400 ))

    if [ "${days_until_expiry}" -le "${WARN_DAYS}" ] && [ "${days_until_expiry}" -gt 0 ]; then
      send_notification \
        "⏰ Tailscale Auth Key Expiring Soon" \
        "The authentication key for ${HOSTNAME} will expire in **${days_until_expiry} days**.\n\nTo prevent disconnection:\n1. Go to https://login.tailscale.com/admin/machines\n2. Find ${HOSTNAME}\n3. Enable 'Disable key expiry'" \
        ${COLOR_WARNING}
    fi
  fi

  # Check 4: Weekly report
  if is_weekly_report_due; then
    send_weekly_report "${current_status}"
  fi

  # Save current state
  echo "${current_status}" > "${STATE_FILE}"
}

main "$@"
