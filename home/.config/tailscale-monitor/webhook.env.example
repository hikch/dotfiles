# Tailscale Monitor - Discord Webhook Configuration
#
# Setup Instructions:
# 1. Copy this file to webhook.env:
#    cp webhook.env.example webhook.env
#
# 2. Get your Discord Webhook URL:
#    - Open Discord server settings
#    - Go to Integrations → Webhooks → New Webhook
#    - Copy the webhook URL
#
# 3. Paste the URL below and save
#
# 4. Protect the file:
#    chmod 600 webhook.env
#
# Note: webhook.env is git-ignored for security

# Discord Webhook URL (required)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"

# Notification settings (optional)
# Uncomment and customize as needed

# Minimum interval between duplicate notifications (in seconds)
# DEFAULT: 3600 (1 hour)
# NOTIFY_COOLDOWN=3600

# Hostname to display in notifications
# DEFAULT: $(hostname -s)
# HOSTNAME="imac-2020"
